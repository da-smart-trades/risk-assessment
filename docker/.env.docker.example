# App
CERT_RA_APP_SECRET_KEY='secret-key'
CERT_RA_APP_DEBUG=true
CERT_RA_APP_URL=http://localhost:8000
CERT_RA_APP_ALLOWED_CORS_ORIGINS=["*"]

# Logging
CERT_RA_LOG_LEVEL=10

# Database
CERT_RA_DB_ECHO=true
CERT_RA_DB_ECHO_POOL=true
CERT_RA_DB_POOL_DISABLED=false
CERT_RA_DB_POOL_MAX_OVERFLOW=5
CERT_RA_DB_POOL_SIZE=5
CERT_RA_DB_POOL_TIMEOUT=30
CERT_RA_DB_URL=postgresql+asyncpg://app:app@db:5432/app
# Dev Postgres requires TLS with a self-signed cert; encrypt without verify.
CERT_RA_DB_SSL_MODE=require

# Vite (set to false for production - no Vite dev server in Docker)
CERT_RA_VITE_DEV_MODE=false

# Temporal
CERT_RA_TEMPORAL_HOST=temporal:7233
CERT_RA_TEMPORAL_NAMESPACE=default
CERT_RA_TEMPORAL_ALERTS_ENABLED=true
# CERT_RA_TEMPORAL_API_KEY=  # Set for Temporal Cloud; enables TLS automatically

# Bootstrap superuser (created once on first startup; skipped if a superuser already exists)
CERT_RA_SUPERUSER_EMAIL=user@certora.com
CERT_RA_SUPERUSER_PASSWORD=change-me-in-production

# Sentry (optional)
# CERT_RA_SENTRY_DSN=

# Blockchain RPCs (free public defaults are built-in; uncomment to use private/paid RPCs)
# CERT_RA_RPC_ETHEREUM_PRIVATE_RPC_1=<your-alchemy-or-infura-url>
# CERT_RA_RPC_ARBITRUM_PRIVATE_RPC_1=<your-private-arbitrum-rpc>
# CERT_RA_RPC_BASE_PRIVATE_RPC_1=<your-private-base-rpc>
# CERT_RA_RPC_POLYGON_PRIVATE_RPC_1=<your-private-polygon-rpc>
# CERT_RA_RPC_OPTIMISM_PRIVATE_RPC_1=<your-private-optimism-rpc>
# CERT_RA_RPC_SOLANA_PRIVATE_RPC_1=<your-helius-or-quicknode-solana-url>
# Avalanche P-Chain (validator/staking) and C-Chain (EVM execution) are separate:
# CERT_RA_RPC_AVALANCHE_P_PRIVATE_RPC_1=<your-private-avalanche-p-chain-rpc>
# CERT_RA_RPC_AVALANCHE_C_PRIVATE_RPC_1=<your-private-avalanche-c-chain-rpc>
# CERT_RA_RPC_INK_URL=<your-ink-rpc-with-optimism_syncStatus-support>
# CERT_RA_RPC_UNICHAIN_URL=<your-unichain-rpc-with-optimism_syncStatus-support>
# Empty values below would override host `../.env` (loaded earlier).
# Leave commented so host secrets win; uncomment only if you want to force-clear.
# ETHEREUM_BEACON_TOKEN=

# Dune Analytics
# CERT_RA_DUNE_API_KEY=

# Rated Network (Ethereum operator/entity decentralization). Get a key at
# https://console.rated.network — operator refresh is skipped when unset.
# CERT_RA_RATED_API_KEY=

