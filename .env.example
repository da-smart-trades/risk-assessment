# ── App ───────────────────────────────────────────────────────────────────────
CERT_RA_APP_URL=http://localhost:8000
CERT_RA_APP_DEBUG=true
CERT_RA_APP_SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Matches the Postgres service in docker/docker-compose.yml (make docker-infra).
# The dev Postgres requires TLS and uses a self-signed cert, so `require` is
# the right SSL mode here (encrypt without verifying the cert).
CERT_RA_DB_URL=postgresql+asyncpg://app:app@localhost:5432/app
CERT_RA_DB_SSL_MODE=require

# ── Temporal ──────────────────────────────────────────────────────────────────
# Local dev: run `temporal server start-dev` to start a local Temporal server.
CERT_RA_TEMPORAL_HOST=localhost:7233
CERT_RA_TEMPORAL_NAMESPACE=default
CERT_RA_TEMPORAL_ALERTS_ENABLED=true
# Temporal Cloud (uncomment and set; TLS is enabled automatically when api_key is set):
# CERT_RA_TEMPORAL_HOST=<account>.tmprl.cloud:7233
# CERT_RA_TEMPORAL_NAMESPACE=<namespace>.<accountid>
# CERT_RA_TEMPORAL_API_KEY=<your-cloud-api-key>

# ── Operator team ─────────────────────────────────────────────────────────────
# The first-party team created on startup. Membership is restricted to users
# whose email domain matches CERT_RA_OPERATOR_TEAM_DOMAIN.
CERT_RA_OPERATOR_TEAM_NAME=Certora
CERT_RA_OPERATOR_TEAM_DOMAIN=certora.com

# ── Bootstrap superuser ───────────────────────────────────────────────────────
# Created once on first startup; ignored when a superuser already exists.
# Email domain must match CERT_RA_OPERATOR_TEAM_DOMAIN (default: certora.com).
# Leave CERT_RA_SUPERUSER_PASSWORD unset to disable automatic creation.
CERT_RA_SUPERUSER_EMAIL=user@certora.com
CERT_RA_SUPERUSER_PASSWORD=change-me-in-production

# ── Data sources ──────────────────────────────────────────────────────────────
# Required for throughput metrics (Dune Analytics)
CERT_RA_DUNE_API_KEY=<your-dune-api-key>
# Required for the Ethereum operator (entity) decentralization panel. Obtain a
# key at https://console.rated.network — the operator refresh workflow is
# skipped when this is unset.
CERT_RA_RATED_API_KEY=<your-rated-network-api-key>


# ── Blockchain RPCs ───────────────────────────────────────────────────────────
# Free public fallbacks are built-in. Override with private/paid RPCs for
# better reliability and rate limits.
# CERT_RA_RPC_ETHEREUM_PRIVATE_RPC_1=<your-alchemy-or-infura-url>
# CERT_RA_RPC_ETHEREUM_PRIVATE_RPC_2=<secondary-private-rpc>
# CERT_RA_RPC_ARBITRUM_PRIVATE_RPC_1=<your-private-arbitrum-rpc>
# CERT_RA_RPC_BASE_PRIVATE_RPC_1=<your-private-base-rpc>
# CERT_RA_RPC_POLYGON_PRIVATE_RPC_1=<your-private-polygon-rpc>
# CERT_RA_RPC_OPTIMISM_PRIVATE_RPC_1=<your-private-optimism-rpc>
# CERT_RA_RPC_SOLANA_PRIVATE_RPC_1=<your-helius-or-quicknode-url>
# Avalanche is split into P-Chain (validator/staking — decentralization) and
# C-Chain (EVM execution — throughput):
# CERT_RA_RPC_AVALANCHE_P_PRIVATE_RPC_1=<your-private-avalanche-p-chain-rpc>
# CERT_RA_RPC_AVALANCHE_C_PRIVATE_RPC_1=<your-private-avalanche-c-chain-rpc>
# Ink and Unichain require optimism_syncStatus support — override defaults only
# if you have a provider that supports it:
# CERT_RA_RPC_INK_URL=<your-quicknode-ink-url>
# CERT_RA_RPC_UNICHAIN_URL=<your-unichain-url>

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
CERT_RA_VITE_DEV_MODE=true

# ── Email (optional) ──────────────────────────────────────────────────────────
# Default backend is 'console' (prints to stdout). Switch to 'resend' for real delivery.
# CERT_RA_EMAIL_ENABLED=true
# CERT_RA_EMAIL_BACKEND=resend
# CERT_RA_EMAIL_FROM_EMAIL=noreply@certora.com
# CERT_RA_EMAIL_RESEND_API_KEY=<your-resend-api-key>

# ── OAuth (optional) ──────────────────────────────────────────────────────────
# CERT_RA_APP_GITHUB_OAUTH2_CLIENT_ID=<client-id>
# CERT_RA_APP_GITHUB_OAUTH2_CLIENT_SECRET=<client-secret>
# CERT_RA_APP_GOOGLE_OAUTH2_CLIENT_ID=<client-id>
# CERT_RA_APP_GOOGLE_OAUTH2_CLIENT_SECRET=<client-secret>
